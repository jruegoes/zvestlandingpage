---
const faqs = [
  { q: "What is Zvest?", a: "Zvest is a simple, all-in-one global phone plan that just works. Enjoy unlimited talk, text, and data worldwide for one price. No hidden fees, roaming charges or hassle." },
  { q: "What countries are you available in?", a: "We're live in 180+ countries. The only places we haven't seen users are a few remote islands or unstable regions like North Korea." },
  { q: "Can I keep my current phone number?", a: "Absolutely, we support US numbers and you can transfer yours directly in the app. Or grab a fresh one if you'd like." },
  { q: "Will it work on my phone?", a: "If your phone supports eSIM and is from the last 5 years, you're good to go." },
  { q: "How much does it cost?", a: "$69/mo including taxes. That's it." },
  { q: "Can I cancel anytime?", a: "No contracts, just pay monthly and cancel anytime." },
];
---

<section class="section cc-home-faq">
  <div class="page-padding">
    <div class="container-pop max-w-[920px] mx-auto">
      <div class="section-header cc-faq">
        <div class="eyebrow-pill">
          <span class="eyebrow-pill-bg u-rainbow u-blur-perf"></span>
          <span class="eyebrow-pill-inner">FAQs</span>
        </div>
        <h2 class="section-heading mt-5">Got questions? Here's the&nbsp;answers.</h2>
      </div>

      <div class="faq-wrap">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary class="faq-header">
              <div>{f.q}</div>
              <span class="faq-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M10.0003 0.833984C15.0629 0.833984 19.167 4.93804 19.167 10.0007C19.167 15.0632 15.0629 19.1673 10.0003 19.1673C4.93774 19.1673 0.83366 15.0632 0.83366 10.0006C0.83366 4.93804 4.93774 0.833984 10.0003 0.833984ZM13.3337 7.57214L14.5122 8.75065L10.0003 13.2625L5.48849 8.75065L6.66699 7.57214L10.0003 10.9055L13.3337 7.57214Z" fill="currentColor"/>
                </svg>
              </span>
            </summary>
            <div class="faq-answer"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
